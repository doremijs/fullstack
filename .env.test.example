# VentoStack — 测试环境环境变量示例
# 复制为 .env.test 后使用: source .env.test
#
# 对应服务启动命令:
#   docker compose -f docker-compose.test.yml up -d

# PostgreSQL — 数据库 / ORM / 迁移测试
TEST_DATABASE_URL=postgresql://vento:ventostack@localhost:15432/ventostack_test

# Redis — Session / Cache / 分布式锁测试
TEST_REDIS_URL=redis://localhost:16379

# Kafka (Redpanda) — MQ 适配器 / 事件总线测试
TEST_KAFKA_BROKERS=localhost:19092

# Jaeger — 分布式追踪 / OpenTelemetry 测试
TEST_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14318

# MailHog — 邮件 / Webhook 测试
TEST_SMTP_HOST=localhost
TEST_SMTP_PORT=18025
TEST_MAILHOG_UI=http://localhost:18026
