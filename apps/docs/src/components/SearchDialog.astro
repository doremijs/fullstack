---
const pagefindTranslations = {
	placeholder: Astro.locals.t('search.label'),
	...Object.fromEntries(
		Object.entries(Astro.locals.t.all())
			.filter(([key]) => key.startsWith('pagefind.'))
			.map(([key, value]) => [key.replace('pagefind.', ''), value])
	),
};

const dataAttributes: DOMStringMap = { 'data-translations': JSON.stringify(pagefindTranslations) };
---

<site-search class={Astro.props.class} {...dataAttributes}>
	<button
		data-open-modal
		disabled
		aria-label={Astro.locals.t('search.label')}
		aria-keyshortcuts="Control+K"
	>
		<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
			<path d="M21.71 20.29 18 16.61A9 9 0 1 0 16.61 18l3.68 3.68a.999.999 0 0 0 1.42 0 1 1 0 0 0 0-1.39ZM11 18a7 7 0 1 1 0-14 7 7 0 0 1 0 14Z"/>
		</svg>
		<span class="sl-hidden md:sl-block" aria-hidden="true">{Astro.locals.t('search.label')}</span>
		<kbd class="sl-hidden md:sl-flex" style="display: none;">
			<kbd>{Astro.locals.t('search.ctrlKey')}</kbd><kbd>K</kbd>
		</kbd>
	</button>

	<dialog style="padding:0" aria-label={Astro.locals.t('search.label')}>
		<div class="dialog-frame sl-flex">
			<button data-close-modal class="sl-flex md:sl-hidden">
				{Astro.locals.t('search.cancelLabel')}
			</button>

			<!-- Tabs -->
			<div class="search-tabs">
				<button class="search-tab active" data-tab="search">搜索文档</button>
				<button class="search-tab" data-tab="ai">Ask AI</button>
			</div>

			<!-- Pagefind Search Panel -->
			<div class="tab-panel active" data-panel="search">
				{
					import.meta.env.DEV ? (
						<div style="margin: auto; text-align: center; white-space: pre-line; padding: 2rem;" dir="ltr">
							<p>{Astro.locals.t('search.devWarning')}</p>
						</div>
					) : (
						<div class="search-container">
							<div id="starlight__search" />
						</div>
					)
				}
			</div>

			<!-- Ask AI Panel -->
			<div class="tab-panel" data-panel="ai">
				<div class="ai-chat">
					<div class="ai-messages"></div>
					<div class="ai-input-area">
						<textarea
							class="ai-input"
							placeholder="问关于 VentoStack 的问题..."
							aria-label="Ask AI"
							rows="1"
						></textarea>
						<button class="ai-send" aria-label="发送">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="22" y1="2" x2="11" y2="13"></line>
								<polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
							</svg>
						</button>
					</div>
					<div class="ai-status"></div>
				</div>
			</div>
		</div>
	</dialog>
</site-search>

<script is:inline>
	(() => {
		const openBtn = document.querySelector('button[data-open-modal]');
		const shortcut = openBtn?.querySelector('kbd');
		if (!openBtn || !(shortcut instanceof HTMLElement)) return;
		const platformKey = shortcut.querySelector('kbd');
		if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
			platformKey.textContent = '\u2318';
			openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
		}
		shortcut.style.display = '';
	})();
</script>

<script>
	import { pagefindUserConfig } from 'virtual:starlight/pagefind-config';

	interface HistoryMessage {
		role: 'user' | 'assistant';
		content: string;
		reasoning?: string;
		sources?: Array<{ title: string; url: string }>;
		timestamp: number;
	}

	const STORAGE_KEY = 'vento-ai-history';
	const PAGE_SIZE = 10;

	function loadHistory(): HistoryMessage[] {
		try {
			const raw = sessionStorage.getItem(STORAGE_KEY);
			return raw ? JSON.parse(raw) : [];
		} catch {
			return [];
		}
	}

	function saveHistory(history: HistoryMessage[]) {
		try {
			sessionStorage.setItem(STORAGE_KEY, JSON.stringify(history.slice(-100)));
		} catch {
			// storage full or disabled
		}
	}

	function appendHistory(msg: HistoryMessage) {
		const history = loadHistory();
		history.push(msg);
		saveHistory(history);
	}

	/** 简单语法高亮（客户端） */
	function highlightCode(code: string): string {
		// 先做 HTML escape
		let text = code
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;');

		const rules: Array<{ regex: RegExp; className: string }> = [
			{ regex: /(\/\/.*$|#.*$)/gm, className: 'token-comment' },
			{ regex: /(["'`])(?:\\.|(?!\1)[^\\\r\n])*\1/g, className: 'token-string' },
			{ regex: /\b(import|export|from|const|let|var|function|class|interface|type|return|async|await|if|else|for|while|switch|case|break|continue|new|this|true|false|null|undefined|try|catch|throw|typeof|instanceof|in|of|extends|implements|static|public|private|protected|readonly|declare|namespace|module|require|default|as|with|yield|debugger)\b/g, className: 'token-keyword' },
			{ regex: /\b\d+(?:\.\d+)?\b/g, className: 'token-number' },
		];

		interface Match { start: number; end: number; className: string; text: string }
		const matches: Match[] = [];

		for (const { regex, className } of rules) {
			let m: RegExpExecArray | null;
			const localRegex = new RegExp(regex.source, regex.flags.includes('g') ? regex.flags : regex.flags + 'g');
			while ((m = localRegex.exec(text)) !== null) {
				matches.push({ start: m.index, end: m.index + m[0].length, className, text: m[0] });
			}
		}

		matches.sort((a, b) => a.start - b.start);
		const unique: Match[] = [];
		let lastEnd = -1;
		for (const m of matches) {
			if (m.start >= lastEnd) {
				unique.push(m);
				lastEnd = m.end;
			}
		}

		let result = '';
		let pos = 0;
		for (const m of unique) {
			result += text.slice(pos, m.start);
			result += `<span class="${m.className}">${m.text}</span>`;
			pos = m.end;
		}
		result += text.slice(pos);
		return result;
	}

	/** 轻量 Markdown 渲染（支持常见格式） */
	function renderMarkdown(text: string): string {
		let html = text
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;');

		// 代码块（带简单语法高亮）
		html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang: string, code: string) => {
			const highlighted = highlightCode(code.trimEnd());
			return `<pre><code class="language-${lang}">${highlighted}</code></pre>`;
		});
		// 行内代码
		html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
		// 加粗
		html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
		// 斜体
		html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
		// 删除线
		html = html.replace(/~~(.+?)~~/g, '<del>$1</del>');
		// 标题
		html = html.replace(/^###### (.+)$/gm, '<h6>$1</h6>');
		html = html.replace(/^##### (.+)$/gm, '<h5>$1</h5>');
		html = html.replace(/^#### (.+)$/gm, '<h4>$1</h4>');
		html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
		html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
		html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
		// 链接
		html = html.replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
		// 表格
		html = html.replace(/(\|[^\n]+\|\n)(\|[-:\|\s]+\|\n)((?:\|[^\n]+\|\n?)+)/g, (match) => {
			const rows = match.trim().split('\n').filter(r => r.trim());
			if (rows.length < 2) return match;
			let table = '<table><thead><tr>';
			const headerCells = rows[0].split('|').map(c => c.trim()).filter(c => c !== '');
			headerCells.forEach(c => { table += `<th>${c}</th>`; });
			table += '</tr></thead><tbody>';
			for (let i = 2; i < rows.length; i++) {
				const cells = rows[i].split('|').map(c => c.trim()).filter(c => c !== '');
				table += '<tr>';
				cells.forEach(c => { table += `<td>${c}</td>`; });
				table += '</tr>';
			}
			table += '</tbody></table>';
			return table;
		});
		// 无序列表行
		html = html.replace(/^[-*] (.+)$/gm, '<li>$1</li>');
		// 有序列表行
		html = html.replace(/^\d+\. (.+)$/gm, '<li>$1</li>');

		// 保护多行 <pre> 块，防止逐行扫描时拆散
		const preBlocks: string[] = [];
		html = html.replace(/<pre[\s\S]*?<\/pre>/g, (match) => {
			const idx = preBlocks.length;
			preBlocks.push(match);
			return `<!--PRE_BLOCK_${idx}-->`;
		});

		// 逐行扫描：空行分段，列表行自动包裹 <ul>，普通行累积为段落
		const lines = html.split('\n');
		const result: string[] = [];
		let paraLines: string[] = [];
		let listItems: string[] = [];

		function flushPara() {
			if (paraLines.length > 0) {
				result.push(`<p>${paraLines.join('<br>')}</p>`);
				paraLines = [];
			}
		}
		function flushList() {
			if (listItems.length > 0) {
				result.push(`<ul>\n${listItems.join('\n')}\n</ul>`);
				listItems = [];
			}
		}

		for (const line of lines) {
			const trimmed = line.trim();
			if (!trimmed) {
				flushPara();
				flushList();
				continue;
			}

			if (trimmed.startsWith('<h') || trimmed.startsWith('<pre')) {
				flushPara();
				flushList();
				result.push(trimmed);
				continue;
			}

			// 还原被保护的 <pre> 块
			const preMatch = trimmed.match(/^<!--PRE_BLOCK_(\d+)-->$/);
			if (preMatch) {
				flushPara();
				flushList();
				result.push(preBlocks[parseInt(preMatch[1], 10)]);
				continue;
			}

			if (trimmed.startsWith('<li')) {
				flushPara();
				listItems.push(trimmed);
				continue;
			}

			// 普通文本
			flushList();
			paraLines.push(trimmed);
		}

		flushPara();
		flushList();

		return result.join('');
	}

	class SiteSearch extends HTMLElement {
		private visibleCount = PAGE_SIZE;
		private aiMessages: HTMLDivElement | null = null;
		private aiInput: HTMLTextAreaElement | null = null;
		private aiSend: HTMLButtonElement | null = null;
		private aiStatus: HTMLDivElement | null = null;

		constructor() {
			super();
			const openBtn = this.querySelector<HTMLButtonElement>('button[data-open-modal]')!;
			const closeBtn = this.querySelector<HTMLButtonElement>('button[data-close-modal]')!;
			const dialog = this.querySelector('dialog')!;
			const dialogFrame = this.querySelector('.dialog-frame')!;

			const onClick = (event: MouseEvent) => {
				const isLink = 'href' in (event.target || {});
				if (
					isLink ||
					(document.body.contains(event.target as Node) &&
						!dialogFrame.contains(event.target as Node))
				) {
					closeModal();
				}
			};

			const openModal = (event?: MouseEvent) => {
				dialog.showModal();
				document.body.toggleAttribute('data-search-modal-open', true);
				this.querySelector('textarea')?.focus();
				event?.stopPropagation();
				window.addEventListener('click', onClick);
			};

			const closeModal = () => dialog.close();

			openBtn.addEventListener('click', openModal);
			openBtn.disabled = false;
			closeBtn.addEventListener('click', closeModal);

			dialog.addEventListener('close', () => {
				document.body.toggleAttribute('data-search-modal-open', false);
				window.removeEventListener('click', onClick);
			});

			window.addEventListener('keydown', (e) => {
				if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
					dialog.open ? closeModal() : openModal();
					e.preventDefault();
				}
			});

			// Tab switching
			const tabs = this.querySelectorAll('.search-tab');
			const panels = this.querySelectorAll('.tab-panel');
			tabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					tabs.forEach((t) => t.classList.remove('active'));
					panels.forEach((p) => p.classList.remove('active'));
					tab.classList.add('active');
					const panelName = tab.getAttribute('data-tab');
					const panel = this.querySelector(`[data-panel="${panelName}"]`);
					panel?.classList.add('active');
					if (panelName === 'ai') {
						this.renderHistory();
					}
				});
			});

			// Pagefind init
			let translations = {};
			try {
				translations = JSON.parse(this.dataset.translations || '{}');
			} catch {}

			const shouldStrip = this.dataset.stripTrailingSlash !== undefined;
			const stripTrailingSlash = (path: string) => path.replace(/(.)(\/#.*)?$/, '$1$2');
			const formatURL = shouldStrip ? stripTrailingSlash : (path: string) => path;

			window.addEventListener('DOMContentLoaded', () => {
				if (import.meta.env.DEV) return;
				const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));
				onIdle(async () => {
					// @ts-expect-error — Missing types for @pagefind/default-ui package.
					const { PagefindUI } = await import('@pagefind/default-ui');
					new PagefindUI({
						...pagefindUserConfig,
						element: '#starlight__search',
						baseUrl: import.meta.env.BASE_URL,
						bundlePath: import.meta.env.BASE_URL.replace(/\/$/, '') + '/pagefind/',
						showImages: false,
						translations,
						showSubResults: true,
						processResult: (result: { url: string; sub_results: Array<{ url: string }> }) => {
							result.url = formatURL(result.url);
							result.sub_results = result.sub_results.map((sub_result) => {
								sub_result.url = formatURL(sub_result.url);
								return sub_result;
							});
						},
					});
				});
			});

			// Ask AI logic
			this.aiInput = this.querySelector<HTMLTextAreaElement>('.ai-input');
			this.aiSend = this.querySelector<HTMLButtonElement>('.ai-send');
			this.aiMessages = this.querySelector<HTMLDivElement>('.ai-messages');
			this.aiStatus = this.querySelector<HTMLDivElement>('.ai-status');

			if (this.aiInput && this.aiSend && this.aiMessages) {
				// textarea 自动高度
				const autoResize = () => {
					this.aiInput!.style.height = 'auto';
					this.aiInput!.style.height = Math.min(this.aiInput!.scrollHeight, 120) + 'px';
				};
				this.aiInput.addEventListener('input', autoResize);

				this.aiSend.addEventListener('click', () => this.sendMessage());
				this.aiInput.addEventListener('keydown', (e) => {
					if (e.key === 'Enter' && !e.shiftKey) {
						e.preventDefault();
						this.sendMessage();
					}
				});
			}
		}

		/** 渲染历史消息（带分页） */
		renderHistory() {
			if (!this.aiMessages) return;
			const history = loadHistory();
			this.aiMessages.innerHTML = '';

			const startIdx = Math.max(0, history.length - this.visibleCount);
			const toShow = history.slice(startIdx);

			// 加载更多按钮
			if (startIdx > 0) {
				const loadMoreBtn = document.createElement('button');
				loadMoreBtn.className = 'ai-load-more';
				loadMoreBtn.textContent = `加载更多历史消息 (${startIdx} 条)`;
				loadMoreBtn.addEventListener('click', () => {
					this.visibleCount += PAGE_SIZE;
					this.renderHistory();
				});
				this.aiMessages.appendChild(loadMoreBtn);
			}

			for (const msg of toShow) {
				this.renderMessage(msg.role, msg.content, msg.reasoning, msg.sources, false);
			}

			this.aiMessages.scrollTop = this.aiMessages.scrollHeight;
		}

		/** 添加单条消息到 UI */
		renderMessage(
			role: 'user' | 'assistant',
			content: string,
			reasoning?: string,
			sources?: Array<{ title: string; url: string }>,
			save = true,
		) {
			if (!this.aiMessages) return null;

			const msg = document.createElement('div');
			msg.className = `ai-message ai-message--${role}`;

			if (role === 'user') {
				msg.textContent = content;
			} else {
				// assistant: reasoning + markdown content + sources
				if (reasoning) {
					const details = document.createElement('details');
					details.className = 'ai-reasoning';
					details.open = true;
					const summary = document.createElement('summary');
					summary.className = 'ai-reasoning-header';
					summary.innerHTML = '思考过程';
					details.appendChild(summary);
					const rc = document.createElement('div');
					rc.className = 'ai-reasoning-text';
					rc.textContent = reasoning;
					details.appendChild(rc);
					msg.appendChild(details);
				}

				const contentEl = document.createElement('div');
				contentEl.className = 'ai-content sl-markdown-content';
				contentEl.innerHTML = renderMarkdown(content);
				msg.appendChild(contentEl);

				if (sources && sources.length > 0) {
					const sourcesEl = document.createElement('div');
					sourcesEl.className = 'ai-sources';
					sourcesEl.innerHTML =
						'<div class="ai-sources-title">参考文档</div>' +
						sources
							.map(
								(s) =>
									`<a href="${s.url}" class="ai-source-link">${s.title}</a>`,
							)
							.join('');
					msg.appendChild(sourcesEl);
				}
			}

			this.aiMessages.appendChild(msg);
			this.aiMessages.scrollTop = this.aiMessages.scrollHeight;

			if (save) {
				appendHistory({ role, content, reasoning, sources, timestamp: Date.now() });
			}

			return msg;
		}

		async sendMessage() {
			if (!this.aiInput || !this.aiSend || !this.aiMessages) return;

			const text = this.aiInput.value.trim();
			if (!text) return;

			// 保存用户消息
			this.renderMessage('user', text, undefined, undefined, true);
			this.aiInput.value = '';
			this.aiInput.style.height = 'auto';
			this.aiSend.disabled = true;
			if (this.aiStatus) this.aiStatus.textContent = '';

			let assistantMsg: HTMLDivElement | null = null;
			let reasoningEl: HTMLDivElement | null = null;
			let contentEl: HTMLDivElement | null = null;
			let sourcesEl: HTMLDivElement | null = null;
			let toolsEl: HTMLDivElement | null = null;
			const toolElements = new Map<string, HTMLDivElement>();
				let toolCallCount = 0;
			let reasoningText = '';
			let contentText = '';
			let sourcesList: Array<{ title: string; url: string }> = [];

			const thinkingMsg = document.createElement('div');
			thinkingMsg.className = 'ai-message ai-message--thinking';
			thinkingMsg.textContent = '思考中...';
			this.aiMessages.appendChild(thinkingMsg);

			// 智能滚动：用户手动上滚后暂停，回到底部时恢复
			let shouldAutoScroll = true;
			const scrollThreshold = 50;
			const onScroll = () => {
				if (!this.aiMessages) return;
				const distance = this.aiMessages.scrollHeight - this.aiMessages.scrollTop - this.aiMessages.clientHeight;
				shouldAutoScroll = distance <= scrollThreshold;
			};
			this.aiMessages.addEventListener('scroll', onScroll);
			const scrollToBottom = () => {
				if (shouldAutoScroll && this.aiMessages) {
					this.aiMessages.scrollTop = this.aiMessages.scrollHeight;
				}
			};

			try {
				const history = loadHistory().slice(-20).map((h) => ({
					role: h.role,
					content: h.content,
				}));

				const response = await fetch('/api/chat', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ message: text, history }),
				});

				if (!response.ok) {
					thinkingMsg.remove();
					const err = await response.json().catch(() => ({ error: 'Request failed' }));
					this.renderMessage('assistant', `错误：${err.error ?? '未知错误'}`);
					return;
				}

				if (!response.body) {
					thinkingMsg.remove();
					this.renderMessage('assistant', '错误：响应流为空');
					return;
				}

				// 收到流式响应，移除网络等待的 thinkingMsg
				thinkingMsg.remove();
				assistantMsg = document.createElement('div');
				assistantMsg.className = 'ai-message ai-message--assistant';
				this.aiMessages.appendChild(assistantMsg);

				const reader = response.body.getReader();
				const decoder = new TextDecoder();
				let buffer = '';

				while (true) {
					const { done, value } = await reader.read();
					if (done) break;
					buffer += decoder.decode(value, { stream: true });

					const lines = buffer.split('\n');
					buffer = lines.pop() || '';

					for (const line of lines) {
						const trimmed = line.trim();
						if (!trimmed.startsWith('data: ')) continue;
						const data = trimmed.slice(6);
						if (data === '[DONE]') continue;
						try {
							const parsed = JSON.parse(data);

							// tool_call
							if (parsed.tool_call && assistantMsg && ++toolCallCount <= 3) {
								if (!toolsEl) {
									toolsEl = document.createElement('div');
									toolsEl.className = 'ai-tools';
									assistantMsg.appendChild(toolsEl);
								}
								const toolEl = document.createElement('div');
								toolEl.className = 'ai-tool ai-tool--running';
								const query = parsed.tool_call.arguments?.query || '';
								const shortQ = query.length > 40 ? query.slice(0, 40) + '...' : query;
								toolEl.innerHTML = `<span class="ai-tool-spinner"></span><span class="ai-tool-name">${parsed.tool_call.name}</span>${shortQ ? `<span class="ai-tool-args">${shortQ}</span>` : ''}`;
								toolsEl.appendChild(toolEl);
								toolElements.set(parsed.tool_call.name + '_' + toolCallCount, toolEl);
							}

							// tool_result
							if (parsed.tool_result && assistantMsg) {
								let el: HTMLDivElement | null = null;
								for (const [key, val] of toolElements) {
									if (key.startsWith(parsed.tool_result.name + '_')) el = val;
								}
								if (el) {
									el.className = 'ai-tool ai-tool--done';
									const result = parsed.tool_result.result as { found?: number; count?: number };
									const count = result?.found ?? result?.count ?? 0;
									el.innerHTML = `<span class="ai-tool-icon">&#10003;</span><span class="ai-tool-name">${parsed.tool_result.name}</span><span class="ai-tool-status">${count} 条结果</span>`;
								}
							}

							// reasoning（思考过程）→ 可展开/收起的面板，带 loading spinner
							const delta = parsed.choices?.[0]?.delta;
							if (delta?.reasoning) {
								reasoningText += delta.reasoning;
								if (!reasoningEl && assistantMsg) {
									reasoningEl = document.createElement('details');
									reasoningEl.className = 'ai-reasoning';
									(reasoningEl as HTMLDetailsElement).open = true;
									const summary = document.createElement('summary');
									summary.className = 'ai-reasoning-header';
									summary.innerHTML = '<span class="ai-reasoning-spinner"></span>思考过程';
									reasoningEl.appendChild(summary);
									const rc = document.createElement('div');
									rc.className = 'ai-reasoning-text';
									reasoningEl.appendChild(rc);
									assistantMsg.appendChild(reasoningEl);
								}
								if (reasoningEl) {
									const rc = reasoningEl.querySelector('.u0061u0069u002du0072u0065u0061u0073u006fu006eu0069u006eu0067u002du0074u0065u0078u0074') as HTMLDivElement;
									if (rc) {
										rc.textContent = reasoningText;
										if ((reasoningEl as HTMLDetailsElement).open) {
											rc.scrollTop = rc.scrollHeight;
										}
									}
								}
							}

							// content（正式回答）→ Markdown 渲染
							if (delta?.content) {
								contentText += delta.content;
								if (!contentEl && assistantMsg) {
									contentEl = document.createElement('div');
									contentEl.className = 'ai-content sl-markdown-content';
									assistantMsg.appendChild(contentEl);
								}
								if (contentEl) {
									contentEl.innerHTML = renderMarkdown(contentText);
									scrollToBottom();
									}
							}

							// sources（参考文档）→ 渲染链接面板
							if (parsed.sources && Array.isArray(parsed.sources)) {
								sourcesList = parsed.sources;
								if (!sourcesEl && assistantMsg) {
									sourcesEl = document.createElement('div');
									sourcesEl.className = 'ai-sources';
									assistantMsg.appendChild(sourcesEl);
								}
								if (sourcesEl) {
									sourcesEl.innerHTML =
										'<div class="ai-sources-title">参考文档</div>' +
										parsed.sources
											.map(
												(s: { title: string; url: string }) =>
													`<a href="${s.url}" class="ai-source-link">${s.title}</a>`,
											)
											.join('');
								}
							}

							this.aiMessages!.scrollTop = this.aiMessages!.scrollHeight;
						} catch {
							// ignore malformed SSE lines
						}
					}
				}

				// flush remaining buffer
				if (buffer.trim().startsWith('data: ')) {
					const data = buffer.trim().slice(6);
					if (data !== '[DONE]') {
						try {
							const parsed = JSON.parse(data);

							if (parsed.tool_call && assistantMsg && ++toolCallCount <= 3) {
								if (!toolsEl) {
									toolsEl = document.createElement('div');
									toolsEl.className = 'ai-tools';
									assistantMsg.appendChild(toolsEl);
								}
								const toolEl = document.createElement('div');
								toolEl.className = 'ai-tool ai-tool--running';
								const query = parsed.tool_call.arguments?.query || '';
								const shortQ = query.length > 40 ? query.slice(0, 40) + '...' : query;
								toolEl.innerHTML = `<span class="ai-tool-spinner"></span><span class="ai-tool-name">${parsed.tool_call.name}</span>${shortQ ? `<span class="ai-tool-args">${shortQ}</span>` : ''}`;
								toolsEl.appendChild(toolEl);
								toolElements.set(parsed.tool_call.name + '_' + toolCallCount, toolEl);
							}

							if (parsed.tool_result && assistantMsg) {
								let el: HTMLDivElement | null = null;
								for (const [key, val] of toolElements) {
									if (key.startsWith(parsed.tool_result.name + '_')) el = val;
								}
								if (el) {
									el.className = 'ai-tool ai-tool--done';
									const result = parsed.tool_result.result as { found?: number; count?: number };
									const count = result?.found ?? result?.count ?? 0;
									el.innerHTML = `<span class="ai-tool-icon">&#10003;</span><span class="ai-tool-name">${parsed.tool_result.name}</span><span class="ai-tool-status">${count} 条结果</span>`;
								}
							}

							const delta = parsed.choices?.[0]?.delta;
							if (delta?.reasoning) {
								reasoningText += delta.reasoning;
								if (!reasoningEl && assistantMsg) {
									reasoningEl = document.createElement('details');
									reasoningEl.className = 'ai-reasoning';
									(reasoningEl as HTMLDetailsElement).open = true;
									const summary = document.createElement('summary');
									summary.className = 'ai-reasoning-header';
									summary.innerHTML = '<span class="ai-reasoning-spinner"></span>思考过程';
									reasoningEl.appendChild(summary);
									const rc = document.createElement('div');
									rc.className = 'ai-reasoning-text';
									reasoningEl.appendChild(rc);
									assistantMsg.appendChild(reasoningEl);
								}
								if (reasoningEl) {
									const rc = reasoningEl.querySelector('.u0061u0069u002du0072u0065u0061u0073u006fu006eu0069u006eu0067u002du0074u0065u0078u0074') as HTMLDivElement;
									if (rc) {
										rc.textContent = reasoningText;
										if ((reasoningEl as HTMLDetailsElement).open) {
											rc.scrollTop = rc.scrollHeight;
										}
									}
								}
							}

							if (delta?.content) {
								contentText += delta.content;
								if (!contentEl && assistantMsg) {
									contentEl = document.createElement('div');
									contentEl.className = 'ai-content sl-markdown-content';
									assistantMsg.appendChild(contentEl);
								}
								if (contentEl) {
									contentEl.innerHTML = renderMarkdown(contentText);
									scrollToBottom();
									}
							}

							if (parsed.sources && Array.isArray(parsed.sources)) {
								sourcesList = parsed.sources;
								if (!sourcesEl && assistantMsg) {
									sourcesEl = document.createElement('div');
									sourcesEl.className = 'ai-sources';
									assistantMsg.appendChild(sourcesEl);
								}
								if (sourcesEl) {
									sourcesEl.innerHTML =
										'<div class="ai-sources-title">参考文档</div>' +
										parsed.sources
											.map(
												(s: { title: string; url: string }) =>
													`<a href="${s.url}" class="ai-source-link">${s.title}</a>`,
											)
											.join('');
								}
							}
						} catch {
							// ignore
						}
					}
				}

				// stream 结束后移除所有 reasoning spinner
				for (const spinner of this.aiMessages!.querySelectorAll('.ai-reasoning-spinner')) {
					spinner.remove();
				}

				// 保存 assistant 完整回复到 history
				if (contentText.trim()) {
					appendHistory({
						role: 'assistant',
						content: contentText,
						reasoning: reasoningText || undefined,
						sources: sourcesList.length > 0 ? sourcesList : undefined,
						timestamp: Date.now(),
					});
				}
			} catch (err) {
				thinkingMsg.remove();
				const errorText = `错误：${err instanceof Error ? err.message : String(err)}`;
				if (assistantMsg) {
					assistantMsg.textContent += '\n' + errorText;
				} else {
					this.renderMessage('assistant', errorText);
				}
			} finally {
				this.aiSend!.disabled = false;
				this.aiInput!.focus();
			}
		}
	}
	customElements.define('site-search', SiteSearch);
</script>

