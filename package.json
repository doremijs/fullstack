{
  "name": "aeron-framework",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "bun --hot apps/example/src/main.ts",
    "dev:doc": "bun run --cwd apps/docs dev",
    "build": "bun run packages/cli/src/build.ts",
    "build:doc": "bun run --cwd apps/docs build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "bun-types": "latest",
    "typescript": "^5.8"
  }
}
